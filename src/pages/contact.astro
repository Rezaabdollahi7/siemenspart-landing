---
import Layout from "@/layouts/Layout.astro";
import Icon from "@/components/ui/Icon.astro";
import Button from "@/components/ui/Button.astro";

const contactInfo = [
  { icon: "phone" as const, label: "تلفن تماس", value: "028-3431948391", dir: "ltr" },
  { icon: "mail" as const, label: "ایمیل", value: "info@siemenspart.com", dir: "ltr" },
  { icon: "map-pin" as const, label: "آدرس", value: "قزوین , شهر صنعتی البرز , بلوار سهروردی , مابین حکمت اول و سوم , ساختمان چمران طبقه ۴", dir: "rtl" },
  { icon: "clock" as const, label: "ساعت کاری", value: "شنبه تا پنجشنبه ۸ تا ۱۷", dir: "rtl" },
];
---

<Layout title="تماس با ما" description="راه‌های ارتباطی با گروه زیمنس‌پارت برای مشاوره فنی، استعلام قیمت و سفارش قطعه.">
  <section class="border-b border-ink-100 bg-ink-50/40 py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold text-ink-900 sm:text-4xl">تماس با ما</h1>
      <p class="mt-4 text-ink-500">برای استعلام قیمت، مشاوره فنی یا هر سوال دیگری، با ما در ارتباط باشید.</p>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="mx-auto grid max-w-6xl gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
      <!-- اطلاعات تماس -->
      <div>
        <div class="grid gap-5 sm:grid-cols-2">
          {
            contactInfo.map((item) => (
              <div class="rounded-2xl border border-ink-100 p-6 shadow-card">
                <div class="flex size-11 items-center justify-center rounded-xl bg-brand-50">
                  <Icon name={item.icon} class="size-5 text-brand-600" />
                </div>
                <p class="mt-4 text-xs font-medium text-ink-400">{item.label}</p>
                <p class="mt-1 text-sm font-medium text-ink-800" dir={item.dir}>
                  {item.value}
                </p>
              </div>
            ))
          }
        </div>

        <div class="mt-8 overflow-hidden rounded-2xl border border-ink-100">
          <iframe
            title="نقشه موقعیت زیمنس‌پارت"
            src="https://www.openstreetmap.org/export/embed.html?bbox=50.07755041122437%2C36.19871999135583%2C50.08109092712403%2C36.20060738785106&amp;layer=mapnik&amp;marker=36.19966369529137%2C50.079320669174194"
            class="h-72 w-full border-0"
            loading="lazy"
          ></iframe>
        </div>
      </div>

      <!-- فرم تماس -->
      <div class="rounded-2xl border border-ink-100 p-8 shadow-card">
        <h2 class="text-lg font-bold text-ink-900">ارسال پیام مستقیم</h2>
        <p class="mt-2 text-sm text-ink-500">فرم زیر را پر کنید تا تیم فروش در سریع‌ترین زمان با شما تماس بگیرد.</p>

        <form class="mt-6 space-y-5">
          <div>
            <label class="mb-1.5 block text-sm font-medium text-ink-700">نام و نام خانوادگی</label>
            <input
              type="text"
              required
              class="h-11 w-full rounded-xl border border-ink-200 px-4 text-sm outline-none focus:border-brand-400 focus:ring-2 focus:ring-brand-100"
            />
          </div>
          <div>
            <label class="mb-1.5 block text-sm font-medium text-ink-700">شماره تماس</label>
            <input
              type="tel"
              dir="ltr"
              required
              class="h-11 w-full rounded-xl border border-ink-200 px-4 text-sm outline-none focus:border-brand-400 focus:ring-2 focus:ring-brand-100"
            />
          </div>
          <div>
            <label class="mb-1.5 block text-sm font-medium text-ink-700">موضوع</label>
            <input
              type="text"
              placeholder="مثلاً: استعلام قیمت موتور سرو Siemens"
              class="h-11 w-full rounded-xl border border-ink-200 px-4 text-sm outline-none focus:border-brand-400 focus:ring-2 focus:ring-brand-100"
            />
          </div>
          <div>
            <label class="mb-1.5 block text-sm font-medium text-ink-700">پیام شما</label>
            <textarea
              rows="4"
              class="w-full rounded-xl border border-ink-200 px-4 py-3 text-sm outline-none focus:border-brand-400 focus:ring-2 focus:ring-brand-100"
            ></textarea>
          </div>
          <Button type="submit" size="lg" class="w-full">ارسال پیام</Button>
        </form>
      </div>
    </div>
  </section>
</Layout>
