---
import Layout from "@/layouts/Layout.astro";
import ProductsExplorer from "@/components/react/ProductsExplorer";
import {
  getAllProducts,
  BRAND_LIST,
  CATEGORY_LIST,
  CATEGORY_LABELS_FA,
  STOCK_LABELS_FA,
} from "@/lib/products";

const products = await getAllProducts();
---

<Layout
  title="محصولات و قطعات یدکی CNC"
  description="جستجو و مشاهده بیش از ۳۰۰ قطعه یدکی اصلی و بازسازی‌شده Siemens، Heidenhain، Indramat، Fanuc و Bosch Rexroth."
>
  <section class="border-b border-ink-100 bg-ink-50/40 py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold text-ink-900 sm:text-4xl">محصولات و قطعات یدکی</h1>
      <p class="mt-3 max-w-2xl text-ink-500">
        مجموعه‌ای کامل از قطعات یدکی اصلی و بازسازی‌شده برای دستگاه‌های CNC صنعتی. برای استعلام قیمت با تیم فروش
        تماس بگیرید.
      </p>
    </div>
  </section>

  <section class="py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <ProductsExplorer
        client:load
        products={products}
        brands={[...BRAND_LIST]}
        categories={[...CATEGORY_LIST]}
        categoryLabels={CATEGORY_LABELS_FA}
        stockLabels={STOCK_LABELS_FA}
      />
    </div>
  </section>
</Layout>
