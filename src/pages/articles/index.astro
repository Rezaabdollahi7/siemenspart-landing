---
import Layout from "@/layouts/Layout.astro";
import Icon from "@/components/ui/Icon.astro";
import { articles } from "@/data/articles";
---

<Layout
  title="مقالات فنی"
  description="راهنماهای فنی و تخصصی در حوزه تعمیر و نگهداری قطعات CNC زیمنس و هایدن‌هاین"
>
  <section class="border-b border-ink-100 bg-ink-50/40 py-14">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold text-ink-900 sm:text-4xl">مقالات فنی</h1>
      <p class="mt-3 max-w-2xl text-ink-500">
        راهنماهای تخصصی برای تشخیص خرابی، تعمیر و نگهداری قطعات CNC صنعتی — نوشته شده توسط تیم فنی سیمنس‌پارت.
      </p>
    </div>
  </section>

  <section class="py-14 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {
          articles.map((article) => (
            <a
              href={`/articles/${article.slug}`}
              class="group flex flex-col overflow-hidden rounded-2xl border border-ink-100 bg-white shadow-card transition-all duration-300 hover:-translate-y-1 hover:border-brand-200 hover:shadow-card-hover"
            >
              <!-- هدر رنگی کارت -->
              <div class="flex h-44 items-center justify-center bg-gradient-to-br from-brand-900 to-ink-800 p-6">
                <div class="text-center">
                  <div class="mx-auto flex size-14 items-center justify-center rounded-2xl bg-brand-500/20 backdrop-blur-sm">
                    <Icon name="wrench" class="size-7 text-brand-300" />
                  </div>
                  <span class="mt-3 inline-block rounded-full bg-brand-500/20 px-3 py-1 text-xs font-medium text-brand-300">
                    {article.category}
                  </span>
                </div>
              </div>

              <div class="flex flex-1 flex-col p-6">
                <div class="flex items-center gap-3 text-xs text-ink-400">
                  <span>{article.date}</span>
                  <span class="size-1 rounded-full bg-ink-300" />
                  <span>{article.readingTime} دقیقه مطالعه</span>
                </div>

                <h2 class="mt-3 text-[15px] font-bold leading-7 text-ink-900 transition-colors group-hover:text-brand-600">
                  {article.title}
                </h2>

                <p class="mt-2 line-clamp-3 flex-1 text-sm leading-7 text-ink-500">
                  {article.excerpt}
                </p>

                <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-brand-600">
                  ادامه مطلب
                  <Icon name="arrow-left" class="size-3.5" />
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
