---
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/ui/Icon.astro";
import SearchBox from "@/components/react/SearchBox";
import { getAllProducts } from "@/lib/products";

const products = await getAllProducts();

const navLinks = [
  { label: "خانه", href: "/" },
  { label: "محصولات", href: "/products" },
  { label: "خدمات", href: "/#services" },
  { label: "درباره ما", href: "/about" },
  { label: "مقالات", href: "/articles" },
  { label: "تماس با ما", href: "/contact" },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="sticky top-0 z-40 border-b border-ink-100 bg-white/85 backdrop-blur-md transition-shadow"
>
  <div class="mx-auto flex h-18 max-w-7xl items-center gap-6 px-4 sm:px-6 lg:px-8">
    <!-- لوگو -->
    <a href="/" class="flex shrink-0 items-center gap-2.5">
      <span class="pt-1 px-3 rounded-md bg-brand-500 text-lg font-bold text-white">
        SIEMENSPART
      </span>
   
    </a>

    <!-- ناوبری دسکتاپ -->
    <nav class="hidden items-center gap-1 lg:flex">
      {
        navLinks.map((link) => {
          const isActive = currentPath === link.href;
          return (
            <a
              href={link.href}
              class:list={[
                "rounded-lg px-3.5 py-2 text-[14px] font-medium transition-colors",
                isActive ? "text-brand-600" : "text-ink-600 hover:text-brand-600 hover:bg-brand-50/60",
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>

    <!-- سرچ (دسکتاپ) -->
    <div class="hidden flex-1 max-w-sm lg:block">
      <SearchBox client:idle products={products} />
    </div>

    <div class="flex-1 lg:hidden"></div>

    <!-- دکمه تماس + همبرگری موبایل -->
    <div class="flex shrink-0 items-center gap-2 mr-auto">
      <Button href="/contact" size="sm" class="hidden sm:inline-flex bg-yellow-400 text-black  px-4">
        <Icon name="phone" class="size-4" />
        ۰۹۱۲۱۸۲۰۸۳۰
      </Button>
      <button
        id="mobile-menu-button"
        class="flex size-10 items-center justify-center rounded-lg text-ink-700 hover:bg-ink-50 lg:hidden"
        aria-label="باز کردن منو"
      >
        <Icon name="menu" class="size-5" />
      </button>
    </div>
  </div>

  <!-- منوی موبایل -->
  <div id="mobile-menu" class="hidden border-t border-ink-100 px-4 pb-4 pt-3 lg:hidden">
    <div class="mb-3">
      <SearchBox client:idle products={products} />
    </div>
    <nav class="flex flex-col gap-1">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="rounded-lg px-3 py-2.5 text-[15px] font-medium text-ink-700 hover:bg-brand-50/60 hover:text-brand-600"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/contact"
        class="mt-2 rounded-xl bg-yellow-500 px-4 py-2.5 text-center text-[15px] font-medium text-black"
      >
        ۰۹۱۲۱۸۲۰۸۳۰
      </a>
    </nav>
  </div>
</header>

<script>
  // باز/بسته کردن منوی موبایل و افکت سایه روی اسکرول — بدون فریم‌ورک، سبک
  const menuButton = document.getElementById("mobile-menu-button");
  const mobileMenu = document.getElementById("mobile-menu");
  const header = document.getElementById("site-header");

  menuButton?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  function onScroll() {
    if (!header) return;
    if (window.scrollY > 8) {
      header.classList.add("shadow-[0_4px_24px_-8px_rgba(14,17,17,0.08)]");
    } else {
      header.classList.remove("shadow-[0_4px_24px_-8px_rgba(14,17,17,0.08)]");
    }
  }
  document.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>
