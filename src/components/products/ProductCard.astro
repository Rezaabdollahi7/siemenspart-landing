---
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import type { ProductEntry } from "@/lib/products";
import { CATEGORY_LABELS_FA, STOCK_LABELS_FA } from "@/lib/products";

interface Props {
  product: ProductEntry;
}

const { product } = Astro.props;

const stockVariant =
  product.stockStatus === "in_stock" ? "success" : product.stockStatus === "limited" ? "warning" : "neutral";
---

<a href={`/products/${product.id}`} class="group block h-full">
  <Card hover class="flex h-full flex-col overflow-hidden p-0">
    <div class="relative aspect-square overflow-hidden bg-ink-50">
      <img
        src={product.image}
        alt={product.title}
        loading="lazy"
        class="size-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
      <Badge variant="brand" class="absolute right-3 top-3 bg-white/95 backdrop-blur-sm">
        {product.brand}
      </Badge>
    </div>

    <div class="flex flex-1 flex-col p-5">
      <p class="text-xs font-medium text-ink-400">{CATEGORY_LABELS_FA[product.category]}</p>
      <h3 class="mt-1.5 line-clamp-2 text-[15px] font-bold leading-6 text-ink-900 transition-colors group-hover:text-brand-600">
        {product.title}
      </h3>
      <p class="mt-1 text-xs text-ink-400" dir="ltr">{product.modelCode}</p>
      <p class="mt-3 line-clamp-2 flex-1 text-sm leading-6 text-ink-500">{product.shortDescription}</p>

      <div class="mt-4 flex items-center justify-between border-t border-ink-100 pt-4">
        <Badge variant={stockVariant}>{STOCK_LABELS_FA[product.stockStatus]}</Badge>
        <span class="text-sm font-medium text-brand-600 group-hover:underline">مشاهده جزئیات</span>
      </div>
    </div>
  </Card>
</a>
