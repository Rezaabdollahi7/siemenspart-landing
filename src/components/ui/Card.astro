---
import { cn } from "@/lib/utils";

interface Props {
  class?: string;
  hover?: boolean;
}

const { class: className, hover = false } = Astro.props;
---

<div
  class={cn(
    "rounded-2xl border border-ink-100 bg-white shadow-card",
    hover && "transition-all duration-300 hover:-translate-y-1 hover:shadow-card-hover hover:border-brand-200",
    className
  )}
>
  <slot />
</div>
