---
// مجموعه آیکون‌های SVG سبک پروژه (بدون وابستگی اضافه برای بخش‌های استاتیک Astro)
interface Props {
  name:
    | "search"
    | "phone"
    | "menu"
    | "close"
    | "chevron-left"
    | "check"
    | "wrench"
    | "package"
    | "shield"
    | "clock"
    | "users"
    | "map-pin"
    | "mail"
    | "arrow-left";
  class?: string;
}
const { name, class: className = "size-5" } = Astro.props;

const paths: Record<string, string> = {
  search: '<circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>',
  phone: '<path d="M3 5a2 2 0 0 1 2-2h2.28a2 2 0 0 1 1.94 1.515l1.06 4.243a2 2 0 0 1-.516 1.937L8.5 11.95a14.5 14.5 0 0 0 5.55 5.55l1.255-1.255a2 2 0 0 1 1.937-.516l4.243 1.06A2 2 0 0 1 23 18.72V21a2 2 0 0 1-2 2h-1C9.954 23 1 14.046 1 4V3a2 2 0 0 1 2-2"/>',
  menu: '<path d="M4 6h16M4 12h16M4 18h16"/>',
  close: '<path d="M18 6 6 18M6 6l12 12"/>',
  "chevron-left": '<path d="m15 18-6-6 6-6"/>',
  check: '<path d="M20 6 9 17l-5-5"/>',
  wrench: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  package: '<path d="M16.5 9.4 7.55 4.24M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.29 7 12 12 20.71 7"/><line x1="12" y1="22" x2="12" y2="12"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  clock: '<circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>',
  users: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  "map-pin": '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/>',
  mail: '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  "arrow-left": '<path d="M19 12H5M12 19l-7-7 7-7"/>',
};
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  set:html={paths[name]}
/>
