---
const testimonials = [
  {
    quote:
      "سرعت بالای  تعمیر و سرویس  دستگاه ها در مجموعه ی مهندس جعفری انقدر بالا است که هیچوقت خط تولیدمون متوقف نشده . متشکر از ایشان و تیم فنی شون . ",
    name: "مهندس رضا موسوی، مدیر فنی گروه صنعتی آریا",
  },
  {
    quote:
      "برای تعمیر چند موتور سرو Siemens به زیمنس‌پارت مراجعه کردیم؛ مشاوره دقیق و قیمت منصفانه تجربه خوبی برامون ساخت.",
    name: "مسئول فنی واحد CNC",
  },
  {
    quote: "از سال ۱۴۰۰ با زیمنس پارت همکاری داریم. تعمیر درایو های  ما رو با کیفیت بسیار بالا و سرعت عالی انجام می‌دن. واقعاً به عنوان یک شریک فنی قابل اعتماد بهشون نگاه می‌کنیم",
    name: "مهندس حسن ابراهیمی، سرپرست تعمیرات کارخانه CNC",
  },
];
---

<section class="py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-ink-900 sm:text-4xl">اعتماد مشتریان صنعتی</h2>
      <p class="mt-4 text-ink-500">بازخورد مشتریانی که در پروژه‌های تعمیر و تامین قطعه با ما همکاری کرده‌اند.</p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {
        testimonials.map((t) => (
          <figure class="rounded-2xl border border-ink-100 bg-white p-7 shadow-card">
            <svg class="size-8 text-brand-200" viewBox="0 0 24 24" fill="currentColor">
              <path d="M9.5 8.5C7 8.5 5 10.5 5 13s2 4.5 4.5 4.5S14 15.5 14 13c0-1.4-.6-2.6-1.6-3.5.2-1.5 1.4-2.7 2.9-2.9V4.5c-3 .2-5.8 2.3-5.8 4z" />
              <path d="M19 8.5c-2.5 0-4.5 2-4.5 4.5s2 4.5 4.5 4.5 4.5-2 4.5-4.5c0-1.4-.6-2.6-1.6-3.5.2-1.5 1.4-2.7 2.9-2.9V4.5c-3 .2-5.8 2.3-5.8 4z" />
            </svg>
            <blockquote class="mt-4 text-sm leading-7 text-ink-600">{t.quote}</blockquote>
            <figcaption class="mt-5 border-t border-ink-100 pt-4 text-sm font-medium text-ink-800">
              {t.name}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
