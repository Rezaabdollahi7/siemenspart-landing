---
import Icon from "@/components/ui/Icon.astro";

// محتوای نمونه ثابت — در آینده می‌تواند به Content Collection مقالات متصل شود
const articles = [
  {
    title: "۵ نشانه برای تشخیص خرابی موتور سرو پیش از توقف کامل",
    excerpt: "بررسی علائم هشداردهنده‌ای که می‌توانند از خرابی جدی موتورهای سروو جلوگیری کنند.",
    date: "۱۲ خرداد ۱۴۰۴",
  },
  {
    title: "تفاوت قطعات اصلی و بازسازی‌شده در دستگاه‌های CNC",
    excerpt: "راهنمای انتخاب بین قطعه اصلی و بازسازی‌شده بر اساس نیاز فنی و بودجه پروژه.",
    date: "۲ خرداد ۱۴۰۴",
  },
  {
    title: "نگهداری پیشگیرانه انکودرها برای افزایش طول عمر دستگاه",
    excerpt: "نکات عملی نگهداری دوره‌ای انکودرهای دورانی برای کاهش خطای موقعیت‌یابی.",
    date: "۲۸ اردیبهشت ۱۴۰۴",
  },
];
---

<section id="articles" class="bg-ink-50/50 py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-ink-900 sm:text-4xl">آخرین مقالات فنی</h2>
      <p class="mt-4 text-ink-500">دانش فنی و راهنمای کاربردی برای نگهداری و تعمیر تجهیزات CNC.</p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        articles.map((article) => (
          <article class="group cursor-pointer rounded-2xl border border-ink-100 bg-white p-7 shadow-card transition-all hover:-translate-y-1 hover:shadow-card-hover hover:border-brand-200">
            <p class="text-xs font-medium text-ink-400">{article.date}</p>
            <h3 class="mt-3 text-[15px] font-bold leading-7 text-ink-900 transition-colors group-hover:text-brand-600">
              {article.title}
            </h3>
            <p class="mt-2 line-clamp-2 text-sm leading-6 text-ink-500">{article.excerpt}</p>
            <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-brand-600">
              ادامه مطلب
              <Icon name="arrow-left" class="size-3.5" />
            </span>
          </article>
        ))
      }
    </div>
  </div>
</section>
