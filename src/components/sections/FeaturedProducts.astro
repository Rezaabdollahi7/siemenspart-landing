---
import ProductCard from "@/components/products/ProductCard.astro";
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/ui/Icon.astro";
import { getFeaturedProducts } from "@/lib/products";

const featured = await getFeaturedProducts(10);
---

<section class="bg-ink-50/50 py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
      <div>
        <h2 class="text-3xl font-bold text-ink-900 sm:text-4xl">محصولات منتخب</h2>
        <p class="mt-3 max-w-xl text-ink-500">گزیده‌ای از محصولات موجود در انبار زیمنس‌پارت</p>
      </div>
      <Button href="/products" variant="outline" size="sm" class="shrink-0">
        مشاهده همه محصولات
        <Icon name="arrow-left" class="size-4" />
      </Button>
    </div>

    <div class="mt-12 -mx-4 flex gap-5 overflow-x-auto px-4 pb-4 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8 [scrollbar-width:thin]">
      {
        featured.map((product) => (
          <div class="w-64 shrink-0 sm:w-72">
            <ProductCard product={product} />
          </div>
        ))
      }
    </div>
  </div>
</section>
