---
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/ui/Icon.astro";
---

<section class="relative overflow-hidden bg-ink-950">
  <!-- تصویر پس‌زمینه -->
  <div class="absolute inset-0">
    <img
      src="/images/hero/heroimg.webp"
      alt=""
      class="size-full object-cover opacity-50"
      fetchpriority="high"
    />
    <!-- لایه گرادیانی روی عکس برای خوانایی متن -->
    <div class="absolute inset-0 bg-linear-to-t from-brand-900/40 via-ink-950/80 to-ink-950/90"></div>
    <svg class="absolute inset-0 h-full w-full opacity-[0.04]" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="48" height="48" patternUnits="userSpaceOnUse">
          <path d="M48 0H0v48" fill="none" stroke="white" stroke-width="1" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
    <div class="absolute -left-32 top-1/3 size-96 rounded-full bg-brand-500/10 blur-3xl"></div>
    <div class="absolute -right-20 bottom-0 size-72 rounded-full bg-brand-400/10 blur-3xl"></div>
  </div>

  <div class="relative mx-auto flex min-h-[95vh] max-w-7xl flex-col items-center justify-center px-4 py-24 text-center sm:px-6 lg:px-8">
    <div class="animate-fade-up mb-6 inline-flex items-center gap-2 rounded-full border border-brand-400/30 bg-brand-500/10 px-4 py-1.5 text-sm font-medium text-brand-300">
      <Icon name="shield" class="size-4" />
      بیش از ۳۰ سال تجربه تخصصی در صنعت CNC
    </div>

    <h1 class="animate-fade-up max-w-4xl text-4xl font-bold leading-[1.3] text-white sm:text-5xl lg:text-6xl" style="animation-delay: 0.08s">
      تعمیرات تخصصی تجهیزات CNC 
      و <span class="text-brand-400">Siemens</span> 
      
    </h1>

    <p class="animate-fade-up mt-6 max-w-2xl text-lg leading-8 text-ink-300" style="animation-delay: 0.16s">
      گروه  مهندسی زیمنس‌ پارت با تکیه بر دانش فنی عمیق و کارگاه تخصصی، خدمات تعمیر، سرویس و تامین قطعات مورد نیاز دستگاه‌ها و درایو های زیمنس
      CNC صنعتی را با بالاترین استاندارد کیفیت ارائه می‌دهد.
    </p>

    <div class="animate-fade-up mt-10 flex flex-col gap-3 sm:flex-row" style="animation-delay: 0.24s">
      <Button href="/products" size="lg">
        مشاهده محصولات
        <Icon name="arrow-left" class="size-4" />
      </Button>
      <Button href="/contact" variant="outline" size="lg" class="border-ink-700 bg-white text-brand-500 hover:border-brand-400 hover:bg-white/5 hover:text-brand-300">
        تماس با ما
      </Button>
    </div>

    <!-- آمار سریع -->
    <div class="animate-fade-up mt-16 grid w-full max-w-2xl grid-cols-3 gap-6 border-t border-white/10 pt-8" style="animation-delay: 0.32s">
      <div>
        <p class="text-2xl font-bold text-white sm:text-3xl">+۳۰۰</p>
        <p class="mt-1 text-xs text-ink-300 sm:text-sm">قطعه یدکی موجود</p>
      </div>
      <div>
        <p class="text-2xl font-bold text-white sm:text-3xl">+۳۰</p>
        <p class="mt-1 text-xs text-ink-300 sm:text-sm">سال تجربه فنی</p>
      </div>
      <div>
        <p class="text-2xl font-bold text-white sm:text-3xl">۲۴/۷</p>
        <p class="mt-1 text-xs text-ink-300 sm:text-sm">مشاوره تخصصی</p>
      </div>
    </div>
  </div>
</section>